# Supabase local development config - obtained when running `pnpm supabase start`

# "Project URL"
VITE_SUPABASE_URL=http://127.0.0.1:54321
# "Authentication Keys -> Publishable"
VITE_SUPABASE_PUBLISHABLE_KEY=[sb_publishable_...rest of key]
# "Authentication Keys -> Secret"
SUPABASE_SECRET_KEY=[sb_secret_...rest of key]

# Smithsonian Institution Open Access API Key
# https://api.data.gov/signup/
SI_OA_API_KEY=

# Optional Sentry local development config.
# Leave disabled unless you want to verify Sentry locally.
# Local development normally only needs the `VITE_SENTRY_*` vars below.
# The server falls back to these values, so separate `SENTRY_*` runtime vars are usually unnecessary locally.
VITE_SENTRY_ENABLED=false
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=local
# Optional explicit browser release. In production builds, leaving this blank
# normally lets the Sentry build plugin auto-detect a release from CI commit
# metadata or the current git SHA.
VITE_SENTRY_RELEASE=
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
VITE_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0.1
VITE_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=1.0

# Optional. Used by `pnpm build` when you want local source map uploads.
SENTRY_AUTH_TOKEN=
