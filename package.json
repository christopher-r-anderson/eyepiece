{
  "name": "eyepiece",
  "private": true,
  "author": "Christopher Anderson <src@christopheranderson.net>",
  "description": "Web UI for the NASA images API",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/christopher-r-anderson/eyepiece.git"
  },
  "type": "module",
  "scripts": {
    "supabase": "supabase",
    "require-supabase": "supabase status > /dev/null 2>&1 || { echo \"Error: Supabase is not running\" >&2; exit 1; }",
    "generate-db-types": "supabase gen types typescript --local > ./src/integrations/supabase/database.types.ts",
    "create-env-local": "./scripts/generate-env.sh > .env.local",
    "create-env-test": "./scripts/generate-env.sh > .env.test",
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "preview": "vite preview",
    "test": "pnpm require-supabase && vitest run",
    "test:unit": "vitest run --project unit",
    "test:integration": "pnpm require-supabase && vitest run --project integration",
    "test:e2e": "pnpm require-supabase && playwright test",
    "serve": "netlify serve",
    "lint": "eslint",
    "format": "prettier -c .",
    "fix": "prettier --write . && eslint --fix",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": "24.x"
  },
  "packageManager": "pnpm@10.30.3",
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@netlify/vite-plugin-tanstack-start": "^1.2.17",
    "@phosphor-icons/react": "^2.1.10",
    "@react-aria/optimize-locales-plugin": "^1.1.5",
    "@react-stately/collections": "^3.12.10",
    "@react-stately/list": "^3.13.4",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.98.0",
    "@tanstack/react-devtools": "^0.9.9",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@tanstack/react-router": "^1.166.2",
    "@tanstack/react-router-devtools": "^1.166.2",
    "@tanstack/react-router-ssr-query": "^1.166.2",
    "@tanstack/react-start": "^1.166.2",
    "@tanstack/react-virtual": "^3.13.20",
    "@tanstack/router-plugin": "^1.166.2",
    "react": "^19.2.4",
    "react-aria": "^3.47.0",
    "react-aria-components": "^1.16.0",
    "react-dom": "^19.2.4",
    "sanitize-html": "^2.17.1",
    "vite-tsconfig-paths": "^6.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tanstack/devtools-vite": "^0.5.3",
    "@tanstack/eslint-config": "^0.4.0",
    "@tanstack/eslint-plugin-query": "^5.91.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.11.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sanitize-html": "^2.16.0",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^10.0.2",
    "jsdom": "^28.1.0",
    "netlify-cli": "^24.0.1",
    "prettier": "^3.8.1",
    "prettier-plugin-sql-cst": "^0.18.0",
    "supabase": "^2.76.17",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "web-vitals": "^5.1.0"
  }
}
